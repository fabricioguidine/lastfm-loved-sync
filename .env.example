# Copy to .env and fill in. .env is gitignored.

# Last.fm API key (read-only). Create one at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Last.fm API shared secret. Required only for the API apply path (`auth` + signed track.love).
LASTFM_SHARED_SECRET=

# Your Last.fm username
LASTFM_USER=

# Session key from `lastfm-loved-sync auth`. When set, `sync --apply` uses the API instead of Playwright.
LASTFM_SESSION_KEY=

# Path to the Playwright session file saved by `lastfm-loved-sync login`
LASTFM_STORAGE_STATE=storage_state.json
